# Copy to .env.local and fill in. Never commit real secrets.

# ── Auth0 ──────────────────────────────────────────────────────────
# A "Regular Web Application" in the budgetmind tenant.
# Generate AUTH0_SECRET with: openssl rand -hex 32
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=                      # e.g. budgetmind.us.auth0.com (no https://)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── Supabase ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=          # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # public anon key
SUPABASE_SERVICE_ROLE_KEY=         # server-only — keep secret
